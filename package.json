{
  "name": "vika-mcp",
  "version": "0.1.1",
  "description": "Vika MCP server over stdio.",
  "type": "module",
  "bin": {
    "vika-mcp": "./bin/vika-mcp.js"
  },
  "main": "./dist/index.js",
  "files": [
    "bin",
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node --eval \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx tests/smoke/smoke.ts"
  },
  "keywords": [
    "mcp",
    "vika",
    "datasheet"
  ],
  "license": "GPL-3.0-only",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "qs": "^6.14.0",
    "undici": "^7.13.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/qs": "^6.14.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
